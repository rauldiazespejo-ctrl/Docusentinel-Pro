{
  "name": "docusentinel-pro",
  "version": "1.0.0",
  "description": "Plataforma de Gestión Integral de Documentos con Verificación de Autenticidad",
  "type": "module",
  "scripts": {
    "dev": "node dist-server/server.mjs",
    "dev:cf": "wrangler pages dev dist --d1=docusentinel-pro --local --ip 0.0.0.0 --port 3000",
    "build": "npm run build:cf && npm run build:server",
    "build:cf": "vite build",
    "build:server": "node build-server.mjs",
    "start": "node dist-server/server.mjs",
    "vercel-build": "npm run build:server",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000/health",
    "git:status": "git status",
    "git:log": "git log --oneline"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.7",
    "jose": "^5.2.0",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241216.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.18.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "esbuild": "^0.27.4",
    "netlify-cli": "^24.0.1",
    "typescript": "^5.3.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  },
  "keywords": [
    "document-management",
    "security",
    "authentication",
    "ai-verification",
    "encryption",
    "audit",
    "cloudflare-pages"
  ],
  "author": "DocuSentinel Team",
  "license": "MIT"
}
