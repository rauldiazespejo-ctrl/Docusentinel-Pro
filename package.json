{
  "name": "docusentinel-pro",
  "version": "1.0.0",
  "description": "Plataforma de Gestión Integral de Documentos con Verificación de Autenticidad",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=docusentinel-pro --local --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=docusentinel-pro --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name docusentinel-pro",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "db:migrate:local": "wrangler d1 migrations apply docusentinel-pro --local",
    "db:migrate:prod": "wrangler d1 migrations apply docusentinel-pro",
    "db:seed": "wrangler d1 execute docusentinel-pro --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute docusentinel-pro --local",
    "db:console:prod": "wrangler d1 execute docusentinel-pro",
    "git:init": "git init && git add . && git commit -m 'Initial commit'",
    "git:commit": "git add . && git commit -m",
    "git:status": "git status",
    "git:log": "git log --oneline"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.12.7",
    "jose": "^5.2.0",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241216.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@types/node": "^20.10.0",
    "netlify-cli": "^24.0.1",
    "typescript": "^5.3.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  },
  "keywords": [
    "document-management",
    "security",
    "authentication",
    "ai-verification",
    "encryption",
    "audit",
    "cloudflare-pages"
  ],
  "author": "DocuSentinel Team",
  "license": "MIT"
}
