# DocuSentinel Pro - Environment Variables
# Copia este archivo a .env y rellena con tus valores reales

# JWT Secret - Usa una cadena aleatoria de al menos 32 caracteres
JWT_SECRET=tu-secreto-jwt-super-seguro-de-al-menos-32-caracteres

# Encryption Key - Debe ser exactamente 32 bytes (32 caracteres)
ENCRYPTION_KEY=12345678901234567890123456789012

# Environment
NODE_ENV=production

# Database (si usas una base de datos externa)
# DATABASE_URL=tu-url-de-base-de-datos

# Email Service (si usas servicio de email)
# EMAIL_API_KEY=tu-api-key-de-email

# SMS Service (si usas servicio SMS)
# SMS_API_KEY=tu-api-key-de-sms